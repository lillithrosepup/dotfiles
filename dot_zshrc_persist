# Persistent zshrc
# This is where my global config goes, because random tools like to add to .zshrc w/o asking


bindkey "^[[1;5C" forward-word
bindkey "^[[1;5D" backward-word

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory

export SSH_AUTH_SOCK=/home/lillith/.var/app/com.bitwarden.desktop/data/.bitwarden-ssh-agent.sock

source ~/.prompt
source ~/.profile
source ~/.aliases
