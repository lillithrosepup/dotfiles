{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": "<#5fafff>● </>"
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "#5fafff",
          "template": "{{ .UserName }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": "@"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#5fafff",
          "template": "{{ .HostName }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": ":"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#d787ff",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#ffffff",
          "template": "$ "
        }
      ]
    }
  ]
}